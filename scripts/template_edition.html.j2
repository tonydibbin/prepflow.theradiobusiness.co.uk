<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Prepflow — {{ full_date }} · Edition</title>
<meta name="description" content="Prepflow edition for {{ full_date }} — news, sport, showbiz, talkback, day notes and forward planning.">
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>
<style>
  :root {
    --bg: #F7F7F5; --paper: #FFFFFF; --ink: #161614; --ink-soft: #2a2a26;
    --muted: #6e6e66; --hairline: #ECECE6; --line: #E2E2DA;
    --accent: #FF4F2E; --accent-soft: #FFE9E2; --break: #FFE9E2;
    --serif: "Fraunces", "Times New Roman", Georgia, serif;
    --sans: "Inter", "Helvetica Neue", system-ui, -apple-system, sans-serif;
    --mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
  }
  * { box-sizing: border-box; }
  html, body { background: var(--bg); color: var(--ink); font-family: var(--sans); margin: 0; padding: 0; font-size: 15px; line-height: 1.55; -webkit-font-smoothing: antialiased; }
  a { color: var(--ink); text-decoration: underline; text-underline-offset: 3px; }
  a:hover { color: var(--accent); }
  .ribbon { background: var(--ink); color: #fff; padding: 12px 28px; display: flex; align-items: center; justify-content: space-between; font-size: 13px; }
  .ribbon .left { display: flex; align-items: center; gap: 12px; }
  .ribbon .badge { background: var(--accent); color: #fff; padding: 3px 10px; border-radius: 4px; font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 1.2px; text-transform: uppercase; }
  .ribbon a { color: #fff; text-decoration: underline; text-underline-offset: 3px; }
  .site-header { background: var(--paper); border-bottom: 1px solid var(--hairline); padding: 18px 28px; display: flex; align-items: center; justify-content: space-between; }
  .wordmark { display: flex; align-items: center; gap: 10px; font-family: var(--sans); font-weight: 600; font-size: 17px; color: var(--ink); text-decoration: none; }
  .wordmark svg { display: block; }
  .nav { display: flex; align-items: center; gap: 22px; }
  .nav a { text-decoration: none; color: var(--ink); font-size: 14px; }
  .nav .pill { background: var(--ink); color: #fff; padding: 7px 14px; border-radius: 999px; font-weight: 500; }
  .wrap { max-width: 920px; margin: 0 auto; padding: 44px 28px 80px 28px; }
  .eyebrow { font-family: var(--mono); font-size: 12px; letter-spacing: 1.3px; text-transform: uppercase; color: var(--muted); margin-bottom: 18px; }
  h1.page-title { font-family: var(--serif); font-weight: 400; font-size: 56px; line-height: 1.05; letter-spacing: -1px; margin: 0 0 16px 0; color: var(--ink); }
  .lede { font-size: 16px; color: var(--ink-soft); max-width: 620px; margin: 0 0 28px 0; }
  .actions { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 28px; }
  .btn { border-radius: 999px; padding: 9px 16px; font-size: 14px; font-weight: 500; border: 1px solid var(--line); background: var(--paper); color: var(--ink); cursor: pointer; font-family: var(--sans); text-decoration: none; display: inline-flex; align-items: center; }
  .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .card { background: var(--paper); border: 1px solid var(--hairline); border-radius: 18px; padding: 28px 30px; margin-bottom: 22px; }
  .card-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }
  .card-num, .card-meta { font-family: var(--mono); font-size: 12px; letter-spacing: 1.3px; text-transform: uppercase; color: var(--muted); }
  .card-meta { letter-spacing: 0.5px; }
  h2.card-title { font-family: var(--serif); font-weight: 400; font-size: 30px; line-height: 1.1; margin: 0 0 22px 0; color: var(--ink); letter-spacing: -0.4px; }
  ul.items { list-style: none; padding: 0; margin: 0; }
  ul.items > li { background: var(--paper); border: 1px solid var(--hairline); border-radius: 14px; padding: 16px 18px; margin-bottom: 10px; display: flex; gap: 16px; }
  ul.items > li:last-child { margin-bottom: 0; }
  ul.items > li .num { flex: 0 0 auto; width: 28px; font-family: var(--serif); font-weight: 400; font-size: 22px; color: var(--muted); line-height: 1.1; padding-top: 1px; }
  ul.items > li .body { flex: 1 1 auto; min-width: 0; }
  ul.items > li .lead { font-weight: 600; color: var(--ink); margin-bottom: 4px; line-height: 1.45; }
  ul.items > li .detail { color: var(--ink-soft); font-size: 14.5px; }
  ul.items > li .tag { font-family: var(--mono); font-size: 11px; letter-spacing: 1.1px; text-transform: uppercase; color: var(--muted); margin-top: 4px; }
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .tile { background: var(--paper); border: 1px solid var(--hairline); border-radius: 14px; padding: 16px 18px; }
  .tile .label { font-family: var(--mono); font-size: 11px; letter-spacing: 1.2px; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
  .tile .value { font-family: var(--serif); font-weight: 400; font-size: 26px; line-height: 1.1; color: var(--ink); margin-bottom: 4px; }
  .tile .sub { font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .pill { display: inline-block; background: #f3f5f8; border: 1px solid var(--line); padding: 2px 8px; border-radius: 999px; font-size: 11px; color: var(--muted); margin-left: 6px; vertical-align: middle; }
  h3.sub { font-family: var(--mono); font-size: 12px; letter-spacing: 1.3px; text-transform: uppercase; color: var(--muted); margin: 22px 0 10px 0; padding-bottom: 6px; border-bottom: 1px solid var(--hairline); }
  h3.sub:first-of-type { margin-top: 8px; }
  .tf-card { background: var(--paper); border: 1px solid var(--hairline); border-radius: 14px; padding: 16px 18px; margin-bottom: 10px; }
  .tf-card .tag { display: inline-block; font-family: var(--mono); font-size: 11px; letter-spacing: 1.3px; text-transform: uppercase; padding: 3px 8px; border-radius: 6px; margin-right: 8px; margin-bottom: 6px; font-weight: 600; }
  .tf-card.fact .tag { background: var(--ink); color: #fff; }
  .tf-card.fiction .tag { background: var(--accent); color: #fff; }
  .qa { font-family: var(--mono); font-size: 12px; letter-spacing: 0.6px; color: var(--muted); margin-top: 6px; text-transform: uppercase; }
  .qa b { color: var(--accent); margin-right: 4px; }
  .cal-month { margin-bottom: 18px; }
  .cal-month .m-head { font-family: var(--mono); font-size: 12px; letter-spacing: 1.3px; text-transform: uppercase; color: var(--muted); border-top: 1px solid var(--hairline); padding-top: 12px; margin-bottom: 8px; }
  .cal-month ul { list-style: none; padding: 0; margin: 0; }
  .cal-month li { display: grid; grid-template-columns: 90px 1fr; gap: 14px; padding: 6px 0; border-bottom: 1px dashed var(--hairline); font-size: 14.5px; }
  .cal-month li:last-child { border-bottom: none; }
  .cal-month li .when { font-family: var(--mono); font-size: 12px; text-transform: uppercase; color: var(--muted); letter-spacing: 0.4px; padding-top: 2px; }
  footer.foot { margin-top: 36px; padding-top: 22px; border-top: 1px solid var(--hairline); color: var(--muted); font-size: 13px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  footer.foot a { color: var(--muted); }
  footer.foot strong { color: var(--ink); font-weight: 600; }
  .print-logo { display: none; }
  @media print {
    @page { size: A4; margin: 24mm 14mm 14mm 14mm; @top-left { content: element(prepLogo); vertical-align: middle; } }
    .print-logo { display: flex; align-items: center; gap: 8px; position: running(prepLogo); font-family: var(--sans); font-weight: 700; font-size: 16px; color: var(--ink); letter-spacing: -0.3px; }
    .print-logo svg { display: block; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    html, body { background: #fff; font-size: 11.5px; line-height: 1.4; }
    .ribbon, .actions { display: none; }
    .site-header { border-bottom: 1px solid var(--hairline); padding: 8px 0; margin-bottom: 6px; }
    .wrap { padding: 0; max-width: 100%; }
    h1.page-title { font-size: 30px; margin-bottom: 6px; }
    .lede { font-size: 12px; margin-bottom: 14px; max-width: 100%; }
    .eyebrow { margin-bottom: 8px; }
    .card { padding: 14px 16px; margin-bottom: 10px; border-radius: 10px; page-break-inside: auto; page-break-before: always; break-before: page; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .card:first-of-type, .card.share-page { page-break-before: avoid; break-before: auto; }
    h2.card-title { font-size: 20px; margin-bottom: 10px; page-break-after: avoid; }
    .card-num, .card-meta { font-size: 10px; }
    ul.items > li { padding: 8px 10px; margin-bottom: 5px; border-radius: 8px; page-break-inside: avoid; }
    ul.items > li .num { width: 22px; font-size: 16px; }
    ul.items > li .lead { font-size: 11.5px; margin-bottom: 2px; }
    ul.items > li .detail { font-size: 11px; }
    ul.items > li .tag { font-size: 9.5px; margin-top: 2px; }
    .tile { padding: 10px 12px; border-radius: 8px; page-break-inside: avoid; }
    .tile .value { font-size: 18px; }
    .tile .label, .tile .sub { font-size: 9.5px; }
    .tf-card { padding: 10px 12px; border-radius: 8px; page-break-inside: avoid; }
    h3.sub { font-size: 10.5px; margin: 12px 0 6px 0; }
    .cal-month .m-head { font-size: 10.5px; padding-top: 8px; margin-bottom: 4px; }
    .cal-month li { padding: 3px 0; font-size: 11px; grid-template-columns: 75px 1fr; }
    .cal-month li .when { font-size: 10px; }
    .nav .pill { background: var(--ink); color: #fff; }
    footer.foot { margin-top: 14px; padding-top: 10px; font-size: 10px; }
  }
</style>
</head>
<body>

<div class="print-logo" aria-hidden="true">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M5 3.5 V20.5 M5 3.5 H11.5 a4.5 4.5 0 0 1 0 9 H5" stroke="#161614" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>
    <circle cx="17.7" cy="6.4" r="2.05" fill="#FF4F2E"/>
  </svg>
  <span>Prepflow</span>
</div>

<div class="ribbon">
  <div class="left">
    <span class="badge">Preview</span>
    <span>Prepflow is in development. This is a design preview.</span>
  </div>
  <a href="mailto:tony@tonydibbin.com?subject=Prepflow%20early%20access">Get early access →</a>
</div>

<header class="site-header">
  <a class="wordmark" href="/">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M5 3.5 V20.5 M5 3.5 H11.5 a4.5 4.5 0 0 1 0 9 H5" stroke="#161614" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="17.7" cy="6.4" r="2.05" fill="#FF4F2E"/>
    </svg>
    Prepflow
  </a>
  <nav class="nav">
    <a href="/#editions">Editions</a>
    <a class="pill" href="/editions/{{ day_name }}.html">Today's edition</a>
    <a href="mailto:tony@tonydibbin.com?subject=Prepflow%20sign%20in">Sign in</a>
  </nav>
</header>

<main class="wrap">

  <div class="eyebrow">Daily Edition · For Tony Dibbin</div>
  <h1 class="page-title">{{ full_date }}.</h1>
  <p class="lede">{{ lede }}</p>

  <div class="actions">
    <a class="btn" href="/">← Back to Prepflow</a>
    <a class="btn" href="/editions/{{ day_name }}.pdf" download>Download PDF</a>
    <a class="btn btn-primary" href="mailto:tony@tonydibbin.com?subject=Prepflow%20early%20access">+ Get early access</a>
  </div>

  {# ===== 01 NEWS ===== #}
  <section class="card" id="sec-news">
    <div class="card-head">
      <span class="card-num">01 — News</span>
      <span class="card-meta">3 stories · max 1 political</span>
    </div>
    <h2 class="card-title">Today's top stories</h2>
    <ul class="items">
      {% for item in news %}
      <li>
        <div class="num">{{ loop.index }}</div>
        <div class="body">
          <div class="lead">{{ item.lead }}</div>
          <div class="detail">{{ item.detail }}</div>
          <div class="tag">{{ item.tag }}</div>
        </div>
      </li>
      {% endfor %}
    </ul>
  </section>

  {# ===== 02 SHOWBIZ ===== #}
  <section class="card" id="sec-showbiz">
    <div class="card-head">
      <span class="card-num">02 — Showbiz</span>
      <span class="card-meta">forward-looking only</span>
    </div>
    <h2 class="card-title">What's coming up</h2>
    <ul class="items">
      {% for item in showbiz %}
      <li>
        <div class="num">{{ loop.index }}</div>
        <div class="body">
          <div class="lead">{{ item.lead }}</div>
          <div class="detail">{{ item.detail }}</div>
          <div class="tag">{{ item.tag }}</div>
        </div>
      </li>
      {% endfor %}
    </ul>
  </section>

  {# ===== 03 SPORT ===== #}
  <section class="card" id="sec-sport">
    <div class="card-head">
      <span class="card-num">03 — Sport</span>
      <span class="card-meta">UK focus · this week</span>
    </div>
    <h2 class="card-title">On the schedule</h2>
    <ul class="items">
      {% for item in sport %}
      <li>
        <div class="num">{{ loop.index }}</div>
        <div class="body">
          <div class="lead">{{ item.lead }}</div>
          <div class="detail">{{ item.detail }}</div>
          <div class="tag">{{ item.tag }}</div>
        </div>
      </li>
      {% endfor %}
    </ul>
  </section>

  {# ===== 04 NEWSBRIEF ===== #}
  <section class="card" id="sec-newsbrief">
    <div class="card-head">
      <span class="card-num">04 — Newsbrief</span>
      <span class="card-meta">light bites · pick &amp; mix</span>
    </div>
    <h2 class="card-title">Quick hits</h2>
    <ul class="items">
      {% for item in newsbrief %}
      <li>
        <div class="num">{{ loop.index }}</div>
        <div class="body">
          <div class="lead">{{ item.lead }}</div>
          <div class="detail">{{ item.detail }}</div>
        </div>
      </li>
      {% endfor %}
    </ul>
  </section>

  {# ===== 05 TALKBACK ===== #}
  <section class="card" id="sec-talkback">
    <div class="card-head">
      <span class="card-num">05 — Talkback</span>
      <span class="card-meta">survey · talk topic · true or false</span>
    </div>
    <h2 class="card-title">For the phone lines</h2>

    <h3 class="sub">Our survey said</h3>
    <ul class="items">
      {% for q in survey %}
      <li>
        <div class="num">Q</div>
        <div class="body">
          <div class="lead">{{ q.question }}</div>
          <div class="qa"><b>Answer:</b> {{ q.answer }}</div>
        </div>
      </li>
      {% endfor %}
    </ul>

    <h3 class="sub">Talk topic</h3>
    <ul class="items">
      {% for t in talk_topic %}
      <li>
        <div class="num">●</div>
        <div class="body">
          <div class="lead">{{ t.lead }}</div>
          <div class="detail">{{ t.detail }}</div>
        </div>
      </li>
      {% endfor %}
    </ul>

    <h3 class="sub">True story or Jackanory — listeners guess</h3>
    <div class="tf-card fact">
      <span class="tag">Fact</span><b>{{ true_false.fact_label }}.</b> {{ true_false.fact }}
    </div>
    <div class="tf-card fiction">
      <span class="tag">Fiction</span><b>Made up, but believable.</b> {{ true_false.fiction }}
    </div>
  </section>

  {# ===== 06 LOTTERY ===== #}
  <section class="card" id="sec-lottery">
    <div class="card-head">
      <span class="card-num">06 — Lottery</span>
      <span class="card-meta">estimated · this week</span>
    </div>
    <h2 class="card-title">Jackpots ahead</h2>
    <div class="grid-2">
      <div class="tile">
        <div class="label">Next EuroMillions Jackpot</div>
        <div class="value">{{ lottery.euromillions_amount }}</div>
        <div class="sub">{{ lottery.euromillions_date }} · estimated</div>
      </div>
      <div class="tile">
        <div class="label">Next National Lottery Jackpot</div>
        <div class="value">{{ lottery.national_amount }}</div>
        <div class="sub">{{ lottery.national_date }} · estimated</div>
      </div>
    </div>
  </section>

  {# ===== 07 FACTS OF THE DAY ===== #}
  <section class="card share-page" id="sec-facts">
    <div class="card-head">
      <span class="card-num">07 — Facts of the Day</span>
      <span class="card-meta">8 to choose from</span>
    </div>
    <h2 class="card-title">Did you know?</h2>
    <ul class="items">
      {% for f in facts %}
      <li>
        <div class="num">●</div>
        <div class="body">
          <div class="lead">{{ f }}</div>
        </div>
      </li>
      {% endfor %}
    </ul>
  </section>

  {# ===== 08 TODAY'S DAY NOTES ===== #}
  <section class="card" id="sec-today">
    <div class="card-head">
      <span class="card-num">08 — Today's Day Notes</span>
      <span class="card-meta">{{ short_date }}</span>
    </div>
    <h2 class="card-title">On this day</h2>

    <p style="margin:0 0 14px 0; color:var(--ink-soft);">{{ today_notes.summary }}</p>

    <h3 class="sub">Today's birthdays</h3>
    <ul class="items">
      {% for b in today_notes.birthdays %}
      <li><div class="num">●</div><div class="body"><div class="lead">{{ b }}</div></div></li>
      {% endfor %}
    </ul>

    <h3 class="sub">The day today</h3>
    <ul class="items">
      {% for e in today_notes.events %}
      <li><div class="num">●</div><div class="body"><div class="lead">{{ e }}</div></div></li>
      {% endfor %}
    </ul>

    <h3 class="sub">Today in music</h3>
    <ul class="items">
      {% for m in today_notes.music %}
      <li><div class="num">●</div><div class="body"><div class="lead">{{ m }}</div></div></li>
      {% endfor %}
    </ul>

    <h3 class="sub">Today in history</h3>
    <ul class="items">
      {% for h in today_notes.history %}
      <li><div class="num">●</div><div class="body"><div class="lead">{{ h }}</div></div></li>
      {% endfor %}
    </ul>
  </section>

  {# ===== 09 TOMORROW'S DAY NOTES ===== #}
  <section class="card" id="sec-tomorrow">
    <div class="card-head">
      <span class="card-num">09 — Tomorrow's Day Notes</span>
      <span class="card-meta">{{ tomorrow_short_date }}</span>
    </div>
    <h2 class="card-title">A peek at tomorrow</h2>

    <p style="margin:0 0 14px 0; color:var(--ink-soft);">{{ tomorrow_notes.summary }}</p>

    <h3 class="sub">Tomorrow's birthdays</h3>
    <ul class="items">
      {% for b in tomorrow_notes.birthdays %}
      <li><div class="num">●</div><div class="body"><div class="lead">{{ b }}</div></div></li>
      {% endfor %}
    </ul>

    <h3 class="sub">The day tomorrow</h3>
    <ul class="items">
      {% for e in tomorrow_notes.events %}
      <li><div class="num">●</div><div class="body"><div class="lead">{{ e }}</div></div></li>
      {% endfor %}
    </ul>

    <h3 class="sub">Tomorrow in music</h3>
    <ul class="items">
      {% for m in tomorrow_notes.music %}
      <li><div class="num">●</div><div class="body"><div class="lead">{{ m }}</div></div></li>
      {% endfor %}
    </ul>
  </section>

  {# ===== 10 FORWARD PLANNING — FILM ===== #}
  <section class="card" id="sec-film">
    <div class="card-head">
      <span class="card-num">10 — Forward Planning · Film</span>
      <span class="card-meta">2026 release schedule</span>
    </div>
    <h2 class="card-title">Coming to cinemas</h2>
    <div class="grid-2">
      <div>
        {% for col in film_calendar.left %}
        <div class="cal-month">
          <div class="m-head">{{ col.month }}</div>
          <ul>
            {% for it in col['items'] %}
            <li><span class="when">{{ it.when }}</span><span>{{ it.what|safe }}</span></li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
      <div>
        {% for col in film_calendar.right %}
        <div class="cal-month">
          <div class="m-head">{{ col.month }}</div>
          <ul>
            {% for it in col['items'] %}
            <li><span class="when">{{ it.when }}</span><span>{{ it.what|safe }}</span></li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ===== 11 FORWARD PLANNING — SPORT ===== #}
  <section class="card" id="sec-sport-cal">
    <div class="card-head">
      <span class="card-num">11 — Forward Planning · Sport</span>
      <span class="card-meta">2026 major events</span>
    </div>
    <h2 class="card-title">On the sporting calendar</h2>
    <div class="grid-2">
      <div>
        {% for col in sport_calendar.left %}
        <div class="cal-month">
          <div class="m-head">{{ col.month }}</div>
          <ul>
            {% for it in col['items'] %}
            <li><span class="when">{{ it.when }}</span><span>{{ it.what|safe }}</span></li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
      <div>
        {% for col in sport_calendar.right %}
        <div class="cal-month">
          <div class="m-head">{{ col.month }}</div>
          <ul>
            {% for it in col['items'] %}
            <li><span class="when">{{ it.when }}</span><span>{{ it.what|safe }}</span></li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

